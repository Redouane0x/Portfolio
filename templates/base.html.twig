<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mon Portfolio{% endblock %}</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
</head>
<body>

<nav class="navbar">
    <div class="logo"> Mon Portfolio.</div>
    <ul class="nav-links">
        <li><a href="#home">{{ 'menu.home'|trans }}</a></li>
        <li><a href="#about">{{ 'menu.about'|trans }}</a></li>
        <li><a href="#resume">{{ 'menu.resume'|trans }}</a></li>
        <li><a href="#projects">{{ 'menu.projects'|trans }}</a></li>
        <li><a href="#hobbies">{{ 'menu.hobbies'|trans }}</a></li>
        <li><a href="#contact">{{ 'menu.contact'|trans }}</a></li>

        <li class="lang-switch">
            <a href="{{ path('app_home', {'_locale': 'fr'}) }}" class="{{ app.request.locale == 'fr' ? 'active-lang' : '' }}">FR</a>
            <span style="color:var(--text-color)">|</span>
            <a href="{{ path('app_home', {'_locale': 'en'}) }}" class="{{ app.request.locale == 'en' ? 'active-lang' : '' }}">EN</a>
        </li>
    </ul>

    </ul>
    <div class="burger">
        <div class="line1"></div>
        <div class="line2"></div>
        <div class="line3"></div>
    </div>
</nav>

{% block body %}{% endblock %}

<footer>
    <div class="socials">
        <a href="https://www.linkedin.com/in/redouane-bouzara" target="_blank" rel="noopener noreferrer">
            <i class="fab fa-linkedin"></i>
        </a></div>
    <p>&copy; {{ "now"|date("Y") }} Bouzara Abderahamane Redouane. Fait avec <span style="color: #64ffda;">Symfony</span>.</p>
</footer>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        once: true
    });
</script>

<script src="{{ asset('js/script.js') }}"></script>
</body>
</html>
